[gpg]
  format = ssh

[gpg "ssh"]
  program = "/opt/1Password/op-ssh-sign"

[commit]
  gpgsign = true

[core]
  sshCommand = "ssh -o IdentitiesOnly=yes -i ~/.ssh/neocredito.pub"

